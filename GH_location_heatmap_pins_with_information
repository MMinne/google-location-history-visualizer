// Mini SVG bar chart
function miniBar(data, tips, color) {
  var maxVal = 0;
  for (var i = 0; i < data.length; i++) if (data[i] > maxVal) maxVal = data[i];
  if (!maxVal) maxVal = 1;
  var w = 258, h = 44, n = data.length, bw = Math.floor((w - n) / n);
  var svg = '<svg width="' + w + '" height="' + h + '" style="display:block;overflow:visible">';
  for (var i = 0; i < n; i++) {
    var bh = Math.max(2, Math.round((data[i] / maxVal) * h));
    svg += '<rect x="' + (i*(bw+1)) + '" y="' + (h-bh) + '" width="' + bw
         + '" height="' + bh + '" fill="' + color + '" rx="1" opacity="0.85">'
         + '<title>' + tips[i] + ': ' + data[i] + ' visits</title></rect>';
  }
  return svg + '</svg>';

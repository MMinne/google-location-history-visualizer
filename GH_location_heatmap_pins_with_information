var strip = document.getElementById("hour-strip"), ticks = [];
for (var h = 0; h < 24; h++) {
  var tick = document.createElement("div");
  tick.className = "hour-tick";
  tick.style.background = PERIOD_COLS[h];
  tick.title = h + ":00";
  (function(hour) {
    tick.addEventListener("click", function() { stopPlay(); showFrame(hour); });
  })(h);
  strip.appendChild(tick);
  ticks.push(tick);
}

var currentFrame = 0, playing = false, timer = null;

function showFrame(idx) {
  currentFrame = ((idx % N) + N) % N;
  slider.value = currentFrame;
  hourLabel.textContent = currentFrame + ":00 - " + currentFrame + ":59";
  hourLabel.style.color = PERIOD_COLS[currentFrame];
  subLabel.textContent  = LABEL_DATA[currentFrame];
  ticks.forEach(function(t, i) {
    t.classList.toggle("active", i === currentFrame);
    t.style.opacity = (i === currentFrame) ? "1" : "0.55";
  });
  if (showHeat) heatLayer.setLatLngs(HEAT_DATA[currentFrame]);
}

function switchMode(weekend) {
  HEAT_DATA  = weekend ? WE_HEAT   : WD_HEAT;
  LABEL_DATA = weekend ? WE_LABELS : WD_LABELS;
  if (weekend) {
    btnWd.className = "mode-btn";
    btnWe.className = "mode-btn active-we";
    modeBadge.textContent = "WEEKEND";
    modeBadge.style.background = "#4a2a6a";
    modeBadge.style.color = "#c47ef4";
  } else {
    btnWd.className = "mode-btn active-wd";
    btnWe.className = "mode-btn";
    modeBadge.textContent = "WEEKDAY";
    modeBadge.style.background = "#1a4a8a";
    modeBadge.style.color = "#7ec8f4";
  }
  showFrame(currentFrame);
}

btnWd.addEventListener("click", function() { stopPlay(); switchMode(false); });
btnWe.addEventListener("click", function() { stopPlay(); switchMode(true);  });

btnHeat.addEventListener("click", function() {
  showHeat = !showHeat;
  if (showHeat) {
    heatLayer.setLatLngs(HEAT_DATA[currentFrame]);
    btnHeat.textContent = "Heatmap ON";  btnHeat.className = "toggle-btn on";
  } else {
    heatLayer.setLatLngs([]);
    btnHeat.textContent = "Heatmap OFF"; btnHeat.className = "toggle-btn off";
  }
});
btnPins.addEventListener("click", function() {
  showPins = !showPins;
  if (showPins) {
    buildPins(); btnPins.textContent = "Pins ON"; btnPins.className = "toggle-btn on";
  } else {
    pinGroup.clearLayers(); btnPins.textContent = "Pins OFF"; btnPins.className = "toggle-btn off";
  }
});

function stepForward() {
  var next = currentFrame + 1;
  if (next >= N) { stopPlay(); return; }
  showFrame(next);
}
function startPlay() {
  playing = true; btnPlay.innerHTML = "&#9646;&#9646;";
  timer = setInterval(stepForward, FRAME_MS);
}
function stopPlay() {
  playing = false; btnPlay.innerHTML = "&#9654;";
  clearInterval(timer); timer = null;
}

btnPlay.addEventListener("click",   function() { playing ? stopPlay() : startPlay(); });
btnPrev.addEventListener("click",   function() { stopPlay(); showFrame(currentFrame - 1); });
btnNext.addEventListener("click",   function() { stopPlay(); showFrame(currentFrame + 1); });
slider.addEventListener("input",    function() { stopPlay(); showFrame(parseInt(slider.value)); });
speedSel.addEventListener("change", function() {
  FRAME_MS = parseInt(speedSel.value);
  if (playing) { stopPlay(); startPlay(); }
});

switchMode(false);
showFrame(0);

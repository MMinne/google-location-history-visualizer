# ---------------------------------------------
# HELPERS
# ---------------------------------------------

def parse_latlng(s: str) -> tuple:
    nums = re.findall(r"[-+]?\d+\.\d+", s)
    return float(nums[0]), float(nums[1])


def parse_time(s: str) -> datetime:
    try:
        return datetime.fromisoformat(s).astimezone(timezone.utc)
    except ValueError:
        s2 = re.sub(r"([+-]\d{2}):(\d{2})$", r"\1\2", s)
        return datetime.strptime(s2, "%Y-%m-%dT%H:%M:%S.%f%z").astimezone(timezone.utc)


def categorise(sem: str) -> tuple:
    for key, (col, label) in SENSITIVE_TYPES.items():
        if key in sem.upper():
            return col, label
    return "#adb5bd", "Cannot determine"


def load_segments(path: str) -> list:
    if not os.path.isfile(path):
        raise FileNotFoundError(f"Cannot find data at: {path}")
    with open(path, encoding="utf-8") as f:
        data = json.load(f)
    segments = data.get("semanticSegments", data) if isinstance(data, dict) else data
    return segments


# ---------------------------------------------
# PARSING — points and visits only
# ---------------------------------------------

def parse_data(segments: list):
    point_rows = []
    visit_rows = []

    for seg in segments:
        try:
            t_start = parse_time(seg["startTime"])
            t_end   = parse_time(seg["endTime"])
        except Exception:
            continue
        if t_end < START_DATE or t_start > END_DATE:
            continue

        local_hour    = (t_start.hour + LOCAL_UTC_OFFSET) % 24
        local_weekday = t_start.weekday()   # 0=Mon...6=Sun
        is_weekend    = local_weekday >= 5

        if "timelinePath" in seg:
            for pt in seg["timelinePath"]:
                try:
                    lat, lon = parse_latlng(pt["point"])
                    t = parse_time(pt["time"])
                    pt_local_hour = (t.hour + LOCAL_UTC_OFFSET) % 24
                    pt_weekend    = t.weekday() >= 5
                    point_rows.append({
                        "time": t, "lat": lat, "lon": lon,
                        "local_hour": pt_local_hour,
                        "is_weekend": pt_weekend,
                    })
                except Exception:
                    continue

        elif "visit" in seg:
            v  = seg["visit"]
            tc = v.get("topCandidate", {})
            loc = tc.get("placeLocation", {}).get("latLng", "")
            if not loc:
                continue
            try:
                lat, lon   = parse_latlng(loc)
                sem        = tc.get("semanticType", "UNKNOWN").upper()
                col, label = categorise(sem)
                dur_min    = (t_end - t_start).total_seconds() / 60
                point_rows.append({
                    "time": t_start, "lat": lat, "lon": lon,
                    "local_hour": local_hour,
                    "is_weekend": is_weekend,
                })
                visit_rows.append({
                    "lat": lat, "lon": lon,
                    "color": col, "label": label,
                    "sem": sem,
                    "duration_min": dur_min,
                    "local_hour":   local_hour,
                    "weekday":      local_weekday,
                    "place_id":     tc.get("placeId", ""),
                })
            except Exception:
                continue

    if not point_rows:
        return pd.DataFrame(), []

    df = pd.DataFrame(point_rows)
    df = df[(df["time"] >= START_DATE) & (df["time"] <= END_DATE)]
    df = df.sort_values("time").reset_index(drop=True)

    # Aggregate visit pins
    # Group by place_id (like peer_classification_tool) for accurate coordinates.
    # Fall back to rounded lat/lon grid for visits with no place_id.
    pins = []
    if visit_rows:
        vdf = pd.DataFrame(visit_rows)

        # Stable group key: prefer Google place_id, else lat/lon ~100m grid
        vdf["group_key"] = vdf["place_id"].where(
            vdf["place_id"] != "",
            "ll:" + vdf["lat"].round(3).astype(str) + "," + vdf["lon"].round(3).astype(str)
        )

        for key, grp in vdf.groupby("group_key"):
            mode_row     = grp.groupby(["color", "label"]).size().idxmax()
            color, label = mode_row
            visit_count  = len(grp)
            total_hours  = grp["duration_min"].sum() / 60
            avg_hours    = total_hours / visit_count if visit_count else 0

            # Median of real coordinates — far more accurate than grid centroid
            lat = round(float(grp["lat"].median()), 5)
            lon = round(float(grp["lon"].median()), 5)

            hour_dist = [0] * 24
            for h in grp["local_hour"]:
                hour_dist[int(h)] += 1

            day_dist = [0] * 7
            for d in grp["weekday"]:
                day_dist[int(d)] += 1

            pins.append({
                "lat":         lat,
                "lon":         lon,
                "color":       color,
                "label":       label,
                "visit_count": visit_count,
                "total_hours": round(total_hours, 2),
                "avg_hours":   round(avg_hours, 2),
                "hour_dist":   hour_dist,
                "day_dist":    day_dist,
            })

        pins = sorted(pins, key=lambda x: x["visit_count"], reverse=True)[:TOP_N_PINS]

    return df, pins


# ---------------------------------------------
# BUILD FRAMES  (heatmap only)
# ---------------------------------------------

def build_frames(df: pd.DataFrame):
    wd_heat, wd_labels = [], []
    we_heat, we_labels = [], []

    df_wd = df[~df["is_weekend"]]
    df_we = df[ df["is_weekend"]]

    for hour in range(24):
        for sub_df, h_list, l_list, day_label in [
            (df_wd, wd_heat, wd_labels, "Weekday"),
            (df_we, we_heat, we_labels, "Weekend"),
        ]:
            pts_df = sub_df[sub_df["local_hour"] == hour]
            if len(pts_df) > MAX_HEAT_PTS:
                pts_df = pts_df.sample(MAX_HEAT_PTS, random_state=42)
            heat_pts = pts_df[["lat", "lon"]].dropna().values.tolist()
            h_list.append(heat_pts)
            l_list.append(
                f"{hour:02d}:00 - {hour:02d}:59  |  {day_label}  |  {len(pts_df):,} pts"
            )

        print(
            f"    Hour {hour:02d}  "
            f"WD: {len(wd_heat[-1]):>4} pts   "
            f"WE: {len(we_heat[-1]):>4} pts"
        )

    return wd_heat, wd_labels, we_heat, we_labels



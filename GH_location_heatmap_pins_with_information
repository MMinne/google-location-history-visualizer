  var color = getColor(p), label = getLabel(p);
  var hourTips = [];
  for (var h = 0; h < 24; h++) hourTips.push(h + ":00");
  var dayTips = ["Mon","Tue","Wed","Thu","Fri","Sat","Sun"];

  var grid = '<div class="classify-grid">';
  for (var c = 0; c < MANUAL_CLASSES.length; c++) {
    var mc = MANUAL_CLASSES[c];
    var isSel = (mc[0] === color && mc[1] === label);
    grid += '<button class="cls-btn' + (isSel ? ' selected' : '') + '" '
          + 'onclick="applyClass(' + idx + ',\\'' + mc[0] + '\\',\\''
          + mc[1].replace(/\'/g, "\\\\'") + '\\')">'
          + '<span class="cls-swatch" style="background:' + mc[0] + '"></span>'
          + mc[1] + '</button>';
  }
  grid += '</div>';

  return '<div class="pin-popup">'
    + '<h3 style="color:' + color + '">&#128205; #' + (idx+1) + ' &mdash; ' + label + '</h3>'
    + '<div class="pin-stats">'
    +   '<div class="pin-stat"><div class="val">' + p.visit_count + '</div><div class="lbl">Visits</div></div>'
    +   '<div class="pin-stat"><div class="val">' + p.avg_hours.toFixed(1) + 'h</div><div class="lbl">Avg / visit</div></div>'
    +   '<div class="pin-stat"><div class="val">' + p.total_hours.toFixed(1) + 'h</div><div class="lbl">Total time</div></div>'
    + '</div>'
    + '<div class="chart-title">Visits by hour of day</div>'
    + miniBar(p.hour_dist, hourTips, "#3a9ad9")
    + '<div class="bar-axis"><span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>23:00</span></div>'
    + '<div class="chart-title">Visits by day of week</div>'
    + miniBar(p.day_dist, dayTips, color)
    + '<div class="bar-axis"><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span></div>'
    + '<div class="classify-section">'
    +   '<div class="chart-title">&#9998; Classify this location</div>'
    +   grid
    + '</div></div>';
}

function applyClass(idx, color, label) {
  pinOverrides[pinKey(PINS_DATA[idx])] = { color: color, label: label };
  buildPins();
  pinGroup.eachLayer(function(lyr) {
    if (lyr._pinIdx === idx) lyr.openPopup();
  });
}

function buildPins() {
  pinGroup.clearLayers();
  for (var i = 0; i < PINS_DATA.length; i++) {
    var p = PINS_DATA[i], color = getColor(p);
    var icon = L.divIcon({
      html: '<div style="width:20px;height:20px;border-radius:50%;background:' + color
          + ';border:2.5px solid rgba(255,255,255,0.85);'
          + 'box-shadow:0 0 10px ' + color + ',0 0 4px rgba(0,0,0,0.9);'
          + 'display:flex;align-items:center;justify-content:center;'
          + 'font-size:9px;font-weight:bold;color:#fff;text-shadow:0 1px 2px rgba(0,0,0,0.8);">'
          + (i+1) + '</div>',
      className: '', iconSize: [20,20], iconAnchor: [10,10]
    });
    var marker = L.marker([p.lat, p.lon], { icon: icon });
    marker._pinIdx = i;
    marker.bindPopup(makePopupHtml(p, i), { maxWidth: 340, minWidth: 290 });
    (function(pin, idx) {
      marker.on("popupopen", function() {
        this.getPopup().setContent(makePopupHtml(pin, idx));
      });
    })(p, i);
    marker.addTo(pinGroup);
  }
}
buildPins();

var showHeat = true, showPins = true;
var slider    = document.getElementById("slider");
